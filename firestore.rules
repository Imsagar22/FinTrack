rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Check if user is logged in
    function isLoggedIn() {
      return request.auth != null;
    }

    // Check if the user is the admin (matching user's email)
    function isAdmin() {
      return isLoggedIn() && (request.auth.token.email == 'sagarmailstop@gmail.com' || request.auth.token.email == 'admin@example.com');
    }

    // Users collection
    match /users/{userId} {
      allow read, write: if isLoggedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read, update, delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isLoggedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }

    // Budgets collection
    match /budgets/{budgetId} {
      allow read, update, delete: if isLoggedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isLoggedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isLoggedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
